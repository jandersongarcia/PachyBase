{
  "name": "pachybase/core",
  "description": "Open-source self-hosted backend foundation for predictable JSON APIs",
  "type": "project",
  "archive": {
    "exclude": [
      "/docs-site"
    ]
  },
  "bin": [
    "pachybase"
  ],
  "require": {
    "vlucas/phpdotenv": "^5.5"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "PachyBase\\Api\\": "api/",
      "PachyBase\\Auth\\": "auth/",
      "PachyBase\\Config\\": "config/",
      "PachyBase\\Database\\": "database/",
      "PachyBase\\Modules\\": "modules/",
      "PachyBase\\Services\\": "services/",
      "PachyBase\\Utils\\": "utils/",
      "PachyBase\\": "core/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "docker-install": "@php scripts/docker-install.php",
    "doctor": "@php scripts/doctor.php",
    "status": "@php scripts/status.php",
    "version": "@php scripts/version.php",
    "test": "phpunit --testdox",
    "db:inspect:entities": "@php scripts/inspect-entities.php",
    "crud:sync": "@php scripts/crud-sync.php",
    "openapi:generate": "@php scripts/openapi-generate.php",
    "ai:build": "@php scripts/ai-build.php",
    "migrations:status": "@php scripts/migrate.php status",
    "migrate": "@php scripts/migrate.php up",
    "migrations:rollback": "@php scripts/migrate.php down",
    "db:seed:status": "@php scripts/seed.php status",
    "db:seed": "@php scripts/seed.php run",
    "db:bootstrap": "@php scripts/bootstrap-database.php",
    "db:fresh": "@php scripts/db-fresh.php"
  }
}

