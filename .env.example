############################################################
# APPLICATION SETTINGS
############################################################

# Application name
APP_NAME=PachyBase

# Application environment
# Possible values: development | production
APP_ENV=development

# Enable debug mode. This should be false in production.
APP_DEBUG=true

# Runtime mode for the project CLI
# Supported values: docker | local
APP_RUNTIME=docker

# Base host, port, and URL used by the CLI status/start commands
APP_HOST=127.0.0.1
APP_PORT=8080
APP_URL=http://localhost:8080

# Main application key used by the auth layer fallback
# APP_KEY=base64:replace_with_a_generated_key

# CORS support for browser-based apps and generated frontends.
# Leave APP_CORS_ALLOWED_ORIGINS empty to keep CORS disabled.
# APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5173
# APP_CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Requested-With,X-Request-Id
# APP_CORS_EXPOSED_HEADERS=
# APP_CORS_ALLOW_CREDENTIALS=false
# APP_CORS_MAX_AGE=600

# Optional request throttling for public-facing deployments.
# APP_RATE_LIMIT_ENABLED=true
# APP_RATE_LIMIT_BACKEND=database
# APP_RATE_LIMIT_MAX_REQUESTS=120
# APP_RATE_LIMIT_WINDOW_SECONDS=60
# APP_RATE_LIMIT_STORAGE_PATH=build/runtime/rate-limit.json

# Optional audit trail for auth events and write operations.
# APP_AUDIT_LOG_ENABLED=true
# APP_AUDIT_LOG_BACKEND=database
# APP_AUDIT_LOG_PATH=build/logs/audit.jsonl

# Multi-tenant workspace defaults.
# TENANCY_HEADER=X-Tenant-Id
# TENANCY_DEFAULT_SLUG=default
# TENANCY_DEFAULT_NAME=Default Workspace


############################################################
# DATABASE CONFIGURATION
############################################################

# Database driver
# Supported for the current release candidate: mysql | pgsql
DB_DRIVER=mysql

# Database host
# When using Docker, this is usually the service name
DB_HOST=db

# Database port
# For mysql: 3306, for pgsql: 5432
DB_PORT=3306

# Database name
DB_DATABASE=pachybase

# Database username
# For mysql: root or a dedicated user, for pgsql: postgres or a dedicated user
DB_USERNAME=pachybase

# Database password
DB_PASSWORD=change_this_password

# PostgreSQL schema (optional, defaults to public)
# DB_SCHEMA=public


############################################################
# AUTHENTICATION
############################################################

# JWT secret. Required in production.
# Generate a strong unique value before publishing.
# AUTH_JWT_SECRET=replace_with_a_strong_secret

# Optional token issuer
# AUTH_JWT_ISSUER=PachyBase

# Access token time-to-live in minutes
# AUTH_ACCESS_TTL_MINUTES=15

# Refresh token time-to-live in days
# AUTH_REFRESH_TTL_DAYS=30

# Bootstrap admin for local development.
# Do not publish with the default password.
# AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@pachybase.local
# AUTH_BOOTSTRAP_ADMIN_PASSWORD=pachybase123
# AUTH_BOOTSTRAP_ADMIN_NAME=PachyBase Admin
