############################################################
# APPLICATION SETTINGS
############################################################

# Application name
APP_NAME=PachyBase

# Application environment
# Possible values: development | production
APP_ENV=development

# Enable debug mode. This should be false in production.
APP_DEBUG=true


############################################################
# DATABASE CONFIGURATION
############################################################

# Database driver
# Supported for the current release candidate: mysql | pgsql
DB_DRIVER=mysql

# Database host
# When using Docker, this is usually the service name
DB_HOST=db

# Database port
# For mysql: 3306, for pgsql: 5432
DB_PORT=3306

# Database name
DB_DATABASE=pachybase

# Database username
# For mysql: root or a dedicated user, for pgsql: postgres or a dedicated user
DB_USERNAME=pachybase

# Database password
DB_PASSWORD=change_this_password

# PostgreSQL schema (optional, defaults to public)
# DB_SCHEMA=public


############################################################
# AUTHENTICATION
############################################################

# JWT secret. Required in production.
# Generate a strong unique value before publishing.
# AUTH_JWT_SECRET=replace_with_a_strong_secret

# Optional token issuer
# AUTH_JWT_ISSUER=PachyBase

# Access token time-to-live in minutes
# AUTH_ACCESS_TTL_MINUTES=15

# Refresh token time-to-live in days
# AUTH_REFRESH_TTL_DAYS=30

# Bootstrap admin for local development.
# Do not publish with the default password.
# AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@pachybase.local
# AUTH_BOOTSTRAP_ADMIN_PASSWORD=pachybase123
# AUTH_BOOTSTRAP_ADMIN_NAME=PachyBase Admin
